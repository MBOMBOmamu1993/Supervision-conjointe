# =====================================================================
#  KoboToolbox — Supervision conjointe PEV / OMS
# =====================================================================
#  Authentification. Le TOKEN est prioritaire ; sinon user/password.
KOBO_TOKEN=55b9dd0d686f98b78888d04cc1f2fe270b7e347f
KOBO_USERNAME=rcm_oms_pev
KOBO_PASSWORD=rcm_oms_pev

#  Instance Kobo (Europe). Ne changez que si vous migrez d'instance.
KOBO_BASE_URL=https://eu.kobotoolbox.org

# =====================================================================
#  Cibles attendues (pour le calcul des « % de réalisation »)
#  Laissez vide si non connu : le % ne s'affichera simplement pas.
# =====================================================================
KOBO_TARGET_CONJOINTE_PEV_OMS=
KOBO_TARGET_CONJOINTE_MCA=
KOBO_TARGET_MCA_SEUL=
KOBO_TARGET_ECZ_SEUL=
KOBO_TARGET_ANTENNES=
KOBO_TARGET_ZS_CONJOINTE=
KOBO_TARGET_ZS_MCA=
KOBO_TARGET_CS_CONJOINTE=
KOBO_TARGET_CS_ECZ=

# =====================================================================
#  Cache serveur (secondes). Le dashboard se resynchronise avec Kobo
#  à l'expiration de ce délai (ou via le bouton « Actualiser »).
# =====================================================================
CACHE_TTL_SECONDS=300

#  TTL court (secondes) pour les onglets « Rapport mensuel des AT » et
#  « Évaluation des AT » — collecte continue, synchronisation temps réel.
AT_CACHE_TTL_SECONDS=60

# =====================================================================
#  SAV — Semaine Africaine de Vaccination
#  Certaines analyses SAV (ventilations par antigène × tranche d'âge, % et
#  nombres d'enfants vaccinés) ont pour source la « BASE SAISIE DONNEES SAV »
#  (Google Sheet). Publiez la feuille en CSV (Fichier → Partager → Publier
#  sur le web → CSV) et collez l'URL ci-dessous. Si vide, le dashboard se
#  replie automatiquement sur les exports Kobo SAV (rendu jamais cassé).
# =====================================================================
SAV_BASE_SAISIE_CSV_URL=
